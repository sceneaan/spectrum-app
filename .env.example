# ============================================================
# Spectrum Mobile App — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
# ============================================================

# --- API ---
# Base URL for all API calls (must include /api suffix)
# main branch  → https://testapi.spectrumclinics.care/api
# prod branch  → https://api.spectrumclinics.care/api
API_URL=https://your-api-domain.com/api

# Base URL for file/media access (no /api suffix)
FILE_URL=https://your-api-domain.com

# Frontend web app URL (used for deep links and redirects)
FRONT_END_URL=https://your-frontend-domain.com

# --- Payment (HyperPay) ---
# Mode: "test" for main branch, "live" for prod branch
HYPERPAY_MODE=test
HYPERPAY_TEST_URL=https://eu-test.oppwa.com/v1/
HYPERPAY_PROD_URL=https://oppwa.com/v1/
PAYMENT_RESULT_URL=https://your-frontend-domain.com/payment-result

# --- Firebase (Push Notifications) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY_IOS=your-firebase-ios-api-key
FIREBASE_API_KEY_ANDROID=your-firebase-android-api-key

# --- App Identity ---
APP_BUNDLE_ID=care.spectrumclinics.app
APP_SCHEME=spectrum
