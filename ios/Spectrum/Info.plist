			<string>spectrum.payments</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>spectrum</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>com.spectrum</string>
		<string>spectrum</string>
		<string>https</string>
		<string>http</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>Spectrum needs camera access to enable video consultations with your healthcare
		providers. For example, during telemedicine appointments, your doctor can see you via
		video to provide medical care and consultations.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Spectrum may use your location to help you find nearby healthcare providers and
		services. Your location data is only used when you are using the app and is never
		shared without your permission.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Spectrum needs microphone access to enable audio communication during video
		consultations with your healthcare providers. For example, during telemedicine
		appointments, you can speak with your doctor to discuss symptoms and receive medical
		advice.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Spectrum needs permission to save images to your photo library when you take photos
		or receive medical documents within the app. For example, when you take a photo of a
		medical test result or receive a document from your healthcare provider, the app can
		save it to your photo library for easy access.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Spectrum needs access to your photo library to allow you to select and upload images
		for your profile picture, medical records, and messaging attachments. For example, you
		can choose a photo from your library to set as your profile picture or attach medical
		documents to share with your healthcare provider.</string>
	<key>NSUserNotificationAlertStyle</key>
	<string>alert</string>
	<key>RCTNewArchEnabled</key>
	<true/>
